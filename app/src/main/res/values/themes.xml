<?xml version="1.0" encoding="utf-8"?>
<resources>

    <!-- Base dark theme -->
    <style name="Theme.PManager" parent="Theme.Material3.Dark.NoActionBar">
        <item name="colorPrimary">@color/secondary</item>
        <item name="colorOnPrimary">@color/on_secondary</item>
        <item name="colorPrimaryContainer">@color/primary</item>
        <item name="colorOnPrimaryContainer">@color/on_primary</item>
        <item name="colorSecondary">@color/secondary</item>
        <item name="colorOnSecondary">@color/on_secondary</item>
        <item name="colorSecondaryContainer">@color/surface_elevated</item>
        <item name="colorOnSecondaryContainer">@color/on_surface</item>
        <item name="colorSurface">@color/surface</item>
        <item name="colorOnSurface">@color/on_surface</item>
        <item name="colorSurfaceVariant">@color/surface_elevated</item>
        <item name="colorOnSurfaceVariant">@color/text_secondary</item>
        <item name="colorError">@color/error</item>
        <item name="colorOnError">@color/on_error</item>
        <item name="android:colorBackground">@color/background</item>
        <item name="colorOnBackground">@color/on_background</item>
        <item name="android:windowBackground">@color/background</item>
        <item name="android:statusBarColor">@color/background</item>
        <item name="android:navigationBarColor">@color/background</item>
        <item name="android:windowLightStatusBar">false</item>

        <!-- Text input styling -->
        <item name="textInputStyle">@style/Widget.PManager.TextInput</item>
    </style>

    <!-- Splash theme -->
    <style name="Theme.PManager.Splash">
        <item name="android:windowBackground">@color/splash_bg</item>
        <item name="android:statusBarColor">@color/splash_bg</item>
        <item name="android:navigationBarColor">@color/splash_bg</item>
    </style>

    <!-- Dialog theme for autofill auth -->
    <style name="Theme.PManager.Dialog" parent="Theme.Material3.Dark.Dialog">
        <item name="colorPrimary">@color/secondary</item>
        <item name="colorSurface">@color/surface</item>
        <item name="android:windowIsFloating">true</item>
    </style>

    <!-- TextInput style -->
    <style name="Widget.PManager.TextInput" parent="Widget.Material3.TextInputLayout.OutlinedBox">
        <item name="boxStrokeColor">@color/text_input_stroke</item>
        <item name="hintTextColor">@color/secondary</item>
        <item name="android:textColorHint">@color/text_hint</item>
    </style>

    <!-- Button styles -->
    <style name="Widget.PManager.Button.Primary" parent="Widget.Material3.Button">
        <item name="backgroundTint">@color/secondary</item>
        <item name="android:textColor">@color/on_secondary</item>
        <item name="cornerRadius">12dp</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:textSize">16sp</item>
        <item name="android:fontFamily">sans-serif-medium</item>
    </style>

    <style name="Widget.PManager.Button.Outlined" parent="Widget.Material3.Button.OutlinedButton">
        <item name="strokeColor">@color/secondary</item>
        <item name="android:textColor">@color/secondary</item>
        <item name="cornerRadius">12dp</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:textSize">16sp</item>
    </style>

    <style name="Widget.PManager.Button.Text" parent="Widget.Material3.Button.TextButton">
        <item name="android:textColor">@color/secondary</item>
        <item name="android:textAllCaps">false</item>
    </style>

    <!-- Card style -->
    <style name="Widget.PManager.Card" parent="Widget.Material3.CardView.Filled">
        <item name="cardBackgroundColor">@color/card_bg</item>
        <item name="cardCornerRadius">16dp</item>
        <item name="cardElevation">0dp</item>
        <item name="contentPadding">16dp</item>
    </style>

    <!-- FAB style -->
    <style name="Widget.PManager.FAB" parent="Widget.Material3.FloatingActionButton.Primary">
        <item name="backgroundTint">@color/secondary</item>
        <item name="tint">@color/on_secondary</item>
    </style>

    <!-- Text styles -->
    <style name="TextAppearance.PManager.Headline" parent="TextAppearance.Material3.HeadlineLarge">
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:fontFamily">sans-serif-medium</item>
    </style>

    <style name="TextAppearance.PManager.Title" parent="TextAppearance.Material3.TitleLarge">
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:fontFamily">sans-serif-medium</item>
    </style>

    <style name="TextAppearance.PManager.Body" parent="TextAppearance.Material3.BodyLarge">
        <item name="android:textColor">@color/text_secondary</item>
    </style>

    <style name="TextAppearance.PManager.Caption" parent="TextAppearance.Material3.BodySmall">
        <item name="android:textColor">@color/text_hint</item>
    </style>

    <!-- Chip style -->
    <style name="Widget.PManager.Chip" parent="Widget.Material3.Chip.Filter">
        <item name="chipBackgroundColor">@color/surface_elevated</item>
        <item name="android:textColor">@color/text_primary</item>
        <item name="chipStrokeColor">@color/divider</item>
        <item name="chipStrokeWidth">1dp</item>
        <item name="checkedIconTint">@color/secondary</item>
    </style>

</resources>
