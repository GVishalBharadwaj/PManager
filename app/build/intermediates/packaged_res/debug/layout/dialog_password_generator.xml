<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@color/surface"
    android:orientation="vertical"
    android:padding="@dimen/spacing_lg">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/generator_title"
        android:textAppearance="@style/TextAppearance.PManager.Title"
        android:textSize="20sp" />

    <!-- Generated Password Display -->
    <com.google.android.material.card.MaterialCardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/spacing_md"
        app:cardBackgroundColor="@color/card_bg"
        app:cardCornerRadius="@dimen/corner_radius_md"
        app:cardElevation="0dp">

        <TextView
            android:id="@+id/tv_generated"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:fontFamily="monospace"
            android:gravity="center"
            android:padding="@dimen/spacing_md"
            android:textColor="@color/secondary"
            android:textIsSelectable="true"
            android:textSize="18sp" />
    </com.google.android.material.card.MaterialCardView>

    <!-- Password Strength -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/spacing_sm"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <ProgressBar
            android:id="@+id/strength_bar"
            style="?android:attr/progressBarStyleHorizontal"
            android:layout_width="0dp"
            android:layout_height="4dp"
            android:layout_weight="1"
            android:max="100" />

        <TextView
            android:id="@+id/tv_strength"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="@dimen/spacing_sm"
            android:textSize="12sp" />
    </LinearLayout>

    <!-- Length Slider -->
    <TextView
        android:id="@+id/tv_length"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/spacing_md"
        android:textColor="@color/text_primary"
        android:textSize="14sp" />

    <com.google.android.material.slider.Slider
        android:id="@+id/slider_length"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:valueFrom="8"
        android:valueTo="64"
        android:stepSize="1"
        android:value="16"
        app:thumbColor="@color/secondary"
        app:trackColorActive="@color/secondary"
        app:trackColorInactive="@color/surface_elevated" />

    <!-- Character Set Toggles -->
    <com.google.android.material.switchmaterial.SwitchMaterial
        android:id="@+id/switch_upper"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/label_uppercase"
        android:textColor="@color/text_primary"
        android:checked="true"
        app:thumbTint="@color/secondary"
        app:trackTint="@color/surface_elevated" />

    <com.google.android.material.switchmaterial.SwitchMaterial
        android:id="@+id/switch_lower"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/label_lowercase"
        android:textColor="@color/text_primary"
        android:checked="true"
        app:thumbTint="@color/secondary"
        app:trackTint="@color/surface_elevated" />

    <com.google.android.material.switchmaterial.SwitchMaterial
        android:id="@+id/switch_digits"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/label_digits"
        android:textColor="@color/text_primary"
        android:checked="true"
        app:thumbTint="@color/secondary"
        app:trackTint="@color/surface_elevated" />

    <com.google.android.material.switchmaterial.SwitchMaterial
        android:id="@+id/switch_special"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/label_special"
        android:textColor="@color/text_primary"
        android:checked="true"
        app:thumbTint="@color/secondary"
        app:trackTint="@color/surface_elevated" />

    <!-- Buttons -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/spacing_md"
        android:orientation="horizontal">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_regenerate"
            style="@style/Widget.PManager.Button.Outlined"
            android:layout_width="0dp"
            android:layout_height="@dimen/button_height"
            android:layout_weight="1"
            android:layout_marginEnd="@dimen/spacing_sm"
            android:text="@string/btn_regenerate" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_use"
            style="@style/Widget.PManager.Button.Primary"
            android:layout_width="0dp"
            android:layout_height="@dimen/button_height"
            android:layout_weight="1"
            android:layout_marginStart="@dimen/spacing_sm"
            android:text="Use" />
    </LinearLayout>
</LinearLayout>
